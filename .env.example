# =========================
# 核心鉴权（必填）
# =========================
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

JWT_SECRET_KEY=change-this-to-a-random-secret-key

# =========================
# 外部 API Key（按需填写）
# =========================
# TAVILY_API_KEY=
# FIRECRAWL_API_KEY=

# ResumeSDK 简历解析 — 阿里云市场版
# RESUMESDK_APPCODE=
# RESUMESDK_APPKEY=
# RESUMESDK_APPSECRET=

# 讯飞语音
# XFYUN_APP_ID=
# XFYUN_API_KEY=
# XFYUN_API_SECRET=

# =========================
# 模型配置
# =========================
# 不要设 LLM_MODEL — 代码内置了 qwen-plus / qwen-max 按用途路由
EMBEDDING_MODEL=text-embedding-v4

# =========================
# PDF 导出
# =========================
PDF_EXPORT_ENGINE=playwright
PDF_EXPORT_TIMEOUT_SECONDS=60
PDF_EXPORT_PAGE_FORMAT=A4
PDF_EXPORT_LOCALE=zh-CN
PDF_EXPORT_FALLBACK_TO_REPORTLAB=true

# =========================
# 应用配置
# =========================
FRONTEND_URL=http://localhost:5173

# 数据库（开发用 SQLite，生产切 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./lumen.db

# Cognee 数据集名（默认全实例共用；与按 user_id 的 SQLite 查询无关）
# COGNEE_DATASET=lumen

# =========================
# 外部数据接入（Phase 2a）
# =========================
# 启用后 Agent 可搜索本地 Markdown/文本笔记（Obsidian 等）
# EXTERNAL_DATA_ENABLED=false
# 多个目录用逗号分隔
# EXTERNAL_DATA_DIRS=C:\Users\you\Obsidian,C:\Users\you\Notes

# DEBUG=true
